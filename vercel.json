{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/map", "destination": "/pages/map.html" },
    { "source": "/about", "destination": "/pages/about.html" },
    { "source": "/shop", "destination": "/pages/shop.html" },
    { "source": "/intelligence", "destination": "/pages/intelligence.html" },
    { "source": "/dashboard", "destination": "/pages/dashboard.html" },
    { "source": "/product", "destination": "/pages/product.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
